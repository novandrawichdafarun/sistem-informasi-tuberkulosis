// ==========================================
// 1. ENTITAS PENGGUNA & FASILITAS KESEHATAN
// ==========================================

Table users {
  id_user integer [pk, increment]
  email varchar(100) [unique, not null]
  password varchar(255) [not null]
  role varchar(20) [note: 'pasien / nakes / super_admin']
}

Table faskes {
  id_faskes integer [pk, increment]
  nama_faskes varchar(100) [not null]
  jenis varchar(50) [note: 'puskesmas / rs / klinik']
  alamat text
}

Table nakes {
  id_nakes integer [pk, increment]
  id_user integer [ref: - users.id_user, unique]
  id_faskes integer [ref: > faskes.id_faskes]
  nama varchar(100) [not null]
  no_str varchar(50) [note: 'Nomor Surat Tanda Registrasi (STR)']
  no_sip varchar(50) [note: 'Surat Izin Praktik (SIP)']
  jabatan varchar(50) [note: 'dokter / perawat / analis lab']
  no_hp varchar(20)
}

// ==========================================
// 2. ENTITAS UTAMA PASIEN & MEDIS
// ==========================================

Table pasien {
  id_pasien integer [pk, increment]
  id_user integer [ref: - users.id_user, unique]
  id_nakes integer [ref: > nakes.id_nakes, note: 'nakes penanggung jawab tetap']
  id_faskes integer [ref: > faskes.id_faskes]
  no_rm varchar(50) [unique]
  nik varchar(16) [unique, not null]
  nama_lengkap varchar(100) [not null]
  tanggal_lahir date
  jenis_kelamin varchar(1) [note: 'L / P']
  alamat text
  no_telp varchar(20)
}

Table episode_pengobatan {
  id_episode integer [pk, increment]
  id_pasien integer [ref: > pasien.id_pasien]
  tanggal_mulai date
  tanggal_selesai date
  tipe_pasien varchar(50) [note: 'kasus baru / kambuh / gagal pengobatan']
  status_episode varchar(20) [note: 'aktif / selesai']
}

// ==========================================
// 3. TRANSAKSI PEMERIKSAAN KESEHATAN
// ==========================================

Table pemeriksaan_klinis {
  id_periksa integer [pk, increment]
  id_episode integer [ref: > episode_pengobatan.id_episode, note: 'Terkunci ke episode untuk riwayat runtun waktu']
  id_nakes integer [ref: > nakes.id_nakes]
  tanggal_periksa date [not null]
  keluhan text
  tensi varchar(20) [note: 'Disimpan teks, contoh: 120/80 mmHg']
  suhu decimal(4,2) [note: 'Desimal presisi, contoh: 36.60']
  pernapasan integer [note: 'Angka bulat per menit']
  nadi integer [note: 'Angka bulat bpm']
  saturasi_o2 integer [note: 'Persentase 0-100']
  tinggi_badan integer
  berat_badan decimal(5,2)
}

Table pemeriksaan_lab {
  id_tes integer [pk, increment]
  id_episode integer [ref: > episode_pengobatan.id_episode]
  id_nakes integer [ref: > nakes.id_nakes]
  tanggal_tes date
  jenis_tes varchar(50) [note: 'TCM / IGRA / Mantoux / BTA / Rontgen']
  periode_pemeriksaan varchar(50) [note: 'Bulan ke-2 / bulan ke-5 / akhir masa pengobatan']
  
  // Data Sample
  jenis_sample varchar(50) [note: 'Sputum (Dahak) / Cairan Serebrospinal (LCS) / Jaringan (Biopsi) / Bilasan Lambung']
  kualitas_sample varchar(50) [note: 'Purulen / Mukoid / Saliva']
  
  // Hasil Tes Khusus Molekuler (TCM) & Kepekaan Obat
  dna_bakteri_tb varchar(50) [note: 'Isi beban kuman khusus TCM: High / Medium / Low / Very Low / Trace']
  status_resistensi_obat varchar(50) [note: 'Resisten / Sensitif / Indeterminate (Terutama untuk Rifampisin pada TCM atau obat lain)']
  
  // Hasil Tes Umum (Untuk Rontgen, Mantoux, IGRA)
  hasil_tes varchar(100) [note: 'Hasil umum: Positif / Negatif / Normal / Kesan TB Paru Aktif']
  
  // Hasil Tes Mikroskopis (BTA)
  hasil_bta varchar(100) [note: 'Khusus tes BTA: Negatif / Scanty (tulis jumlahnya) / 1+ / 2+ / 3+']

  catatan_lab text
  berkas_pendukung_url varchar(255)
}

Table diagnosis {
  id_diagnosis integer [pk, increment]
  id_episode integer [ref: - episode_pengobatan.id_episode, unique, note: 'Satu diagnosis final per satu episode pengobatan']
  id_nakes integer [ref: > nakes.id_nakes, note: 'Dokter yang menegakkan diagnosis']
  tanggal_diagnosis date [not null]

  // Standarisasi Medis
  kode_icd10 varchar(10) [note: 'Contoh: A15.0 (TB Paru), A18.2 (TB Kelenjar)']
  klasifikasi_anatomi varchar(50) [note: 'TB Paru / TB Ekstraparu']
  lokasi_anatomi_detail varchar(100) [note: 'Jika Ekstraparu, sebutkan: Kelenjar getah bening / Pleura / Meninges / Tulang']

  // Kesimpulan Resistensi (Pondasi penentu jenis regimen obat)
  klasifikasi_resistensi varchar(50) [note: 'TB-SO (Sensitif Obat) / TB-RO (Resisten Obat) / Terduga TB-RO']
  tipe_resistensi_detail varchar(50) [note: 'Monoresisten Rifampisin (TB-RR) / MDR-TB / XDR-TB / Null jika SO']

  // Dasar Penegakan Diagnosis
  dasar_diagnosis varchar(50) [note: 'Terkonfirmasi Bakteriologis (TCM/BTA+) / Terdiagnosis Klinis (Gejala + Rontgen)']
  catatan_klinis text [note: 'Catatan tambahan dokter terkait kondisi komorbid seperti TB-HIV atau TB-DM']
}

Table resep_pengobatan {
  id_resep integer [pk, increment]
  id_episode integer [ref: > episode_pengobatan.id_episode]
  id_nakes integer [ref: > nakes.id_nakes, note: 'Dokter yang meresepkan']
  tanggal_resep date [not null]

  // Klasifikasi Rejimen
  kategori_regimen varchar(50) [note: 'Kategori 1 (2RHZE/4RH) / Kategori 2 / OAT Anak / Rejimen TB-RO Jangka Pendek / Rejimen TB-RO Jangka Panjang']
  fase_pengobatan varchar(20) [note: 'Intensif / Lanjutan']

  // Manajemen Waktu
  tanggal_mulai_obat date [not null]
  durasi_hari integer [note: 'Durasi resep berlaku, misal: 28 hari atau 56 hari']
  status_resep varchar(20) [note: 'aktif / selesai / diganti']
}

Table detail_obat {
  id_detail integer [pk, increment]
  id_resep integer [ref: > resep_pengobatan.id_resep]

  // Detail Fisik Obat
  nama_obat varchar(100) [note: 'Contoh: KDT Lini 1 (4FDC), Streptomisin vial, Levofloxacin 250mg, Rifampisin 450mg']
  jenis_obat varchar(50) [note: 'KDT (Kombinasi Dosis Tetap) / Tunggal / Injeksi']

  // Aturan Pakai & Dosis (Sangat krusial berdasarkan berat badan pasien)
  jumlah_obat_per_minum decimal(4,2) [note: 'Contoh: 3.00 (artinya 3 tablet sekali minum), atau 1.50 (1 setengah tablet)']
  frekuensi_minum varchar(50) [note: '1x sehari / 3x seminggu / 1x seminggu']
  aturan_pakai varchar(100) [note: 'Sebelum makan / sesudah makan / saat perut kosong pagi hari']
  jumlah_total_diberikan integer [note: 'Total fisik obat yang dibawa pulang pasien, misal: 84 tablet']
}

Table jadwal_minum_obat {
  id_jadwal integer [pk, increment]
  id_resep integer [ref: > resep_pengobatan.id_resep]
  id_detail_obat integer [ref: > detail_obat.id_detail, note: 'Spesifik ke obatnya']
  tanggal_jadwal date [not null]
  jam_jadwal time [not null]
  status_pengingat varchar(20) [default: 'pending', note: 'pending / terkirim / gagal_kirim']
}

Table medication_log {
  id_log integer [pk, increment]
  id_jadwal integer [ref: - jadwal_minum_obat.id_jadwal, note: 'Cukup lewat jadwal untuk tahu relasi pasien']
  status varchar(20) [note: 'diminum / terlewat / ditunda']
  waktu_aktual_diminum timestamp [note: 'Mencatat waktu asli saat tombol "Sudah Minum" diklik di aplikasi']
  reported_by varchar(20) [note: 'pasien_mandiri / pmo_keluarga / pmo_nakes']
  catatan_kepatuhan text [note: 'Alasan jika obat terlewat/ditunda, misal: muntah, pusing berat, atau lupa bawa obat']
}

Table hasil_akhir {
  id_hasil integer [pk, increment]
  id_episode integer [ref: - episode_pengobatan.id_episode, unique]
  tanggal_selesai date
  status_akhir varchar(50) [note: 'sembuh / lengkap / gagal / putus obat / meninggal / pindah']
}

// ==========================================
// 4. ENTITAS PENDUKUNG (NOTIFIKASI & CHAT)
// ==========================================

Table notifikasi {
  id_notifikasi integer [pk, increment]
  id_user integer [ref: > users.id_user, note: 'Mengarah ke id_user penerima email/notif']
  judul varchar(50) [note: 'pengingat obat', not null]
  pesan text [not null]
  waktu_kirim timestamp
  status_terkirim varchar(20)
}

Table pesan_chat {
  id_pesan integer [pk, increment]
  id_pasien integer [ref: > pasien.id_pasien, note: 'Menentukan room chat pasien tersebut']
  id_pengirim integer [ref: > users.id_user, note: 'ID akun yang mengetik pesan']
  isi_pesan text
  lampiran_file_url varchar(255)
  waktu_kirim timestamp [default:  `now()` ]
  status_baca varchar(20) [note: 'dibaca / belum dibaca']
}

Table user_session {
  id integer [pk, increment]
  id_user integer [ref: - users.id_user, unique]
  session_token text [not null]
  device_info text
  last_active_at timestamp [default: 'now()', not null]
}